# =============================================================
#  n8n-veille-emploi-fr — variables d'environnement
#  Copie ce fichier en `.env` puis remplis les valeurs.
#  NE COMMITE JAMAIS ton fichier `.env` réel (voir .gitignore).
# =============================================================

# --- n8n : clé de chiffrement des credentials ---
# Génère une chaîne aléatoire, ex : openssl rand -hex 24
N8N_ENCRYPTION_KEY=change_moi_par_une_chaine_aleatoire_longue

# Hôte et URL publique (laisse tel quel pour un usage local)
N8N_HOST=localhost
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=Europe/Paris

# --- Google Gemini ---
# Modèle utilisé pour l'extraction. gemini-2.5-flash est rapide et suffisant.
GEMINI_MODEL=gemini-2.5-flash

# --- Notion ---
# ID de la base Notion où écrire les offres (32 caractères).
# On l'obtient depuis l'URL de la base — voir MANUAL_STEPS.md.
NOTION_DATABASE_ID=colle_ici_l_id_de_ta_base_notion

# --- Notification ---
# Adresse qui reçoit le récapitulatif à chaque nouvelle offre.
NOTIFICATION_EMAIL=ton.adresse@example.com

# --- Source Gmail (optionnel) ---
# Requête de recherche Gmail pour ne déclencher que sur les bons mails.
# Exemples : "from:alertes@linkedin.com", "subject:alerte emploi", "newer_than:2d".
# Laisse vide pour déclencher sur tout nouveau mail reçu.
GMAIL_SEARCH_QUERY=
